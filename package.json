{
  "name": "workspace",
  "engines": {
    "node": "20"
  },
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "db:push": "pnpm --filter @workspace/db run push",
    "build": "pnpm run typecheck && pnpm -r run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "tsc --build --emitDeclarationOnly || true"
  },
  "pnpm": {
    "frozen-lockfile": false
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
