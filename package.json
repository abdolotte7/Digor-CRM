{
  "name": "workspace",
  "engines": { "node": ">=22.12.0" },
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx prisma generate || true",
    "build": "npx prisma generate && pnpm run typecheck && pnpm -r run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "tsc --build --emitDeclarationOnly || true"
  },
  "pnpm": {
    "frozen-lockfile": false
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}

