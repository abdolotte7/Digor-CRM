# ==============================================================================
# Digor CRM & Tools — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is listed in .gitignore.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/digor

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-string

# Super admin account (seeded on first startup)
CRM_ADMIN_EMAIL=admin@yourdomain.com
CRM_ADMIN_PASSWORD=replace-with-secure-password

# Tools portal PIN (numeric, 4–8 digits recommended)
TOOLS_PIN=0000

# ------------------------------------------------------------------------------
# AI / LLM
# ------------------------------------------------------------------------------
GROQ_API_KEY=gsk_...
# Optional: override the default model
# AI_MODEL=llama-3.1-70b-versatile

# ------------------------------------------------------------------------------
# Property Data & Valuations
# ------------------------------------------------------------------------------
# ATTOM Data Solutions
ATTOM_API_KEY=your-attom-primary-key
ATTOM_API_KEY_2=your-attom-secondary-key   # optional — enables automatic rotation

# PropertyAPI.co (supports up to 7 keys in round-robin rotation)
PROPERTY_API_KEY=your-propertyapi-key       # legacy single-key (still supported)
PROPERTY_API_KEY_1=your-propertyapi-key-1
PROPERTY_API_KEY_2=your-propertyapi-key-2
PROPERTY_API_KEY_3=your-propertyapi-key-3
PROPERTY_API_KEY_4=your-propertyapi-key-4  # optional
PROPERTY_API_KEY_5=your-propertyapi-key-5  # optional
PROPERTY_API_KEY_6=your-propertyapi-key-6  # optional
PROPERTY_API_KEY_7=your-propertyapi-key-7  # optional

# Rentcast (optional — enables rental/sale AVM in CRM)
RENTCAST_API_KEY=your-rentcast-key

# ------------------------------------------------------------------------------
# Communications
# ------------------------------------------------------------------------------
# SignalWire (optional — enables VoIP call/SMS logging)
SIGNALWIRE_PROJECT_ID=your-signalwire-project-id
SIGNALWIRE_API_TOKEN=your-signalwire-api-token
SIGNALWIRE_SPACE_URL=your-space.signalwire.com

# OpenPhone (optional — alternative telephony provider)
OPENPHONE_API_KEY=your-openphone-key

# SMTP (optional — required for automated email sequences)
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-smtp-password

# ------------------------------------------------------------------------------
# Payments
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
